# Brewfile.desktop — GUI Mac apps for day-to-day personal use.
# Hand-curated. Never auto-regenerated; edit it directly.
#
# Cascade: install AFTER Brewfile.minimum and Brewfile.homeserver. Entries
# here intentionally exclude anything already in minimum (warp, obsidian,
# skim, microsoft-edge, brave-browser, comet, vscode, github, claude,
# coteditor, markedit, cyberduck, mountain-duck, visualdiffer, hookmark,
# 1password, fastscripts, betterdisplay, karabiner-elements, raycast,
# rectangle, rectangle-pro, default-folder-x, shottr, typinator,
# rocket-typist, thaw@beta, microsoft-office, Velja, OwlOCR, Juicy,
# Home Assistant) and anything in Brewfile.games.
#
# Use:  brew bundle install --file=setup/homebrew/Brewfile.desktop

# Taps providing GUI apps
tap "davep/homebrew"
tap "nailuogg/recoll"  # for recoll
tap "steipete/tap"  # for codexbar
tap "xykong/tap" # for flux-markdown
tap "steipete/tap"  # for codexbar

# Productivity / Office
cask "busycal"  # Calendar software focusing on flexibility and reliability
cask "busycontacts"  # Contact manager focusing on efficiency
cask "elmedia-player"  # Video and audio player
cask "firefox"  # Web browser
cask "markdown-service-tools"  # Collection of services for Markdown-formatted text
#cask "send-to-kindle"  # Tool for sending personal documents to Kindles from Macs
cask "soulver"  # Notepad with a built-in calculator
cask "textexpander"  # Inserts pre-made snippets of text anywhere
cask "tripmode"  # Control your data usage on slow or expensive networks
cask "microsoft-teams"
cask "flux-markdown" # Markdown editor with live preview and support for Mermaid diagrams

# Email
cask "emclient"  # Email client for Windows and macOS https://www.emclient.com/
cask "mailspring"  # Email client https://getmailspring.com/
cask "superhuman"  # paid Email client https://superhuman.com/
cask "mimestream"  # Native app email client for Gmail

