# Copy to ~/.config/rclone/obsidian-remotely-save.env and chmod 600 it.
#
# Add a new vault by:
#   1. Adding its slug to OBSIDIAN_REMOTELY_SAVE_VAULTS
#   2. Adding BUCKET, ENDPOINT, KEY_ID, and APPLICATION_KEY variables below
#
# Slugs may use letters, numbers, underscores, and hyphens. Variable names use
# the uppercased slug with non-alphanumeric characters converted to underscores.

export OBSIDIAN_REMOTELY_SAVE_DEST_ROOT="$HOME/Obsidian Remotely Save"
export OBSIDIAN_REMOTELY_SAVE_VAULTS="personal-bg swgoh dnd"

export OBSIDIAN_REMOTELY_SAVE_PERSONAL_BG_BUCKET="obsidian-personal-bg"
export OBSIDIAN_REMOTELY_SAVE_PERSONAL_BG_ENDPOINT="s3.us-west-001.backblazeb2.com"
export OBSIDIAN_REMOTELY_SAVE_PERSONAL_BG_KEY_ID="0011f574de89f060000000008"
export OBSIDIAN_REMOTELY_SAVE_PERSONAL_BG_APPLICATION_KEY="put-application-key-here"

export OBSIDIAN_REMOTELY_SAVE_SWGOH_BUCKET="obsidian-bg-SWGOH"
export OBSIDIAN_REMOTELY_SAVE_SWGOH_ENDPOINT="s3.us-west-001.backblazeb2.com"
export OBSIDIAN_REMOTELY_SAVE_SWGOH_KEY_ID="0011f574de89f060000000009"
export OBSIDIAN_REMOTELY_SAVE_SWGOH_APPLICATION_KEY="put-application-key-here"

export OBSIDIAN_REMOTELY_SAVE_DND_BUCKET="obsidian-bg-DND"
export OBSIDIAN_REMOTELY_SAVE_DND_ENDPOINT="s3.us-west-001.backblazeb2.com"
export OBSIDIAN_REMOTELY_SAVE_DND_KEY_ID="0011f574de89f06000000000a"
export OBSIDIAN_REMOTELY_SAVE_DND_APPLICATION_KEY="put-application-key-here"
