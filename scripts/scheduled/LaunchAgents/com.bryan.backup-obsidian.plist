<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Back up ~/Obsidian Master → Backblaze B2 via restic (every 4 hours). -->
	<key>Label</key>
	<string>com.bryan.backup-obsidian</string>
	<key>ProgramArguments</key>
	<array>
		<string>/Users/bryan/bin/scripts/scheduled/backup-obsidian.sh</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StartInterval</key>
	<integer>14400</integer>
	<key>StandardErrorPath</key>
	<string>/tmp/backup-obsidian.err</string>
	<key>StandardOutPath</key>
	<string>/tmp/backup-obsidian.out</string>
</dict>
</plist>
